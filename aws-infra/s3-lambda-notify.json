{
  "LambdaFunctionConfigurations": [
    {
      "Id": "offline-sync-trigger",
      "LambdaFunctionArn": "arn:aws:lambda:ap-south-1:718980965213:function:studaxis-offline-sync",
      "Events": ["s3:ObjectCreated:*"],
      "Filter": {
        "Key": {
          "FilterRules": [
            {"Name": "prefix", "Value": "sync/"},
            {"Name": "suffix", "Value": ".json"}
          ]
        }
      }
    }
  ]
}
