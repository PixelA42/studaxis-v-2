# ═══════════════════════════════════════════════════════════════════════════════
# Studaxis — Environment Configuration Template
# ═══════════════════════════════════════════════════════════════════════════════
# Copy to .env and fill in values. NEVER commit .env or real credentials.
# ═══════════════════════════════════════════════════════════════════════════════

# ─────────────────────────────────────────────────────────────────────────────
# SMTP / Email (OTP & Verification)
# ─────────────────────────────────────────────────────────────────────────────
STUDAXIS_SMTP_HOST=
STUDAXIS_SMTP_PORT=587
STUDAXIS_SMTP_USER=
STUDAXIS_SMTP_PASS=

# Gmail: Use App Password (Account → Security → 2-Step Verification → App passwords)
# Alternate names: SMTP_HOST, SMTP_PORT, SMTP_USER, SMTP_PASSWORD

# ─────────────────────────────────────────────────────────────────────────────
# API Keys (load from env — never hardcode)
# ─────────────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=
DATABASE_URL=

# ─────────────────────────────────────────────────────────────────────────────
# Auth (required for production)
# ─────────────────────────────────────────────────────────────────────────────
STUDAXIS_JWT_SECRET=

# ─────────────────────────────────────────────────────────────────────────────
# Local AI (Ollama)
# ─────────────────────────────────────────────────────────────────────────────
OLLAMA_HOST=http://localhost:11434
OLLAMA_BASE_URL=http://localhost:11434
STUDAXIS_OLLAMA_MODEL=

# ─────────────────────────────────────────────────────────────────────────────
# ChromaDB / Embeddings
# ─────────────────────────────────────────────────────────────────────────────
CHROMA_DB_PATH=./data/chromadb
EMBEDDING_MODEL=all-MiniLM-L6-v2

# ─────────────────────────────────────────────────────────────────────────────
# AWS / AppSync (optional — for cloud sync)
# ─────────────────────────────────────────────────────────────────────────────
AWS_REGION=ap-south-1
APPSYNC_ENDPOINT=
APPSYNC_API_KEY=
S3_BUCKET_NAME=
S3_BUCKET_STUDENT=
S3_BUCKET_CONTENT=

# ─────────────────────────────────────────────────────────────────────────────
# App Settings
# ─────────────────────────────────────────────────────────────────────────────
STUDAXIS_BASE_PATH=
STUDAXIS_PORT=6782
STUDAXIS_VERIFY_BASE_URL=http://localhost:5173
