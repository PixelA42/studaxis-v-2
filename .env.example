# Local App Configuration
OLLAMA_MODEL=llama3:3b
OLLAMA_HOST=http://localhost:11434
CHROMA_DB_PATH=./data/chromadb
USER_STATS_PATH=./data/user_stats.json
EMBEDDING_MODEL=all-MiniLM-L6-v2

# AWS Configuration (discovered: aws appsync list-graphql-apis, s3 ls, lambda list-functions)
AWS_REGION=ap-south-1
S3_BUCKET_NAME=studaxis-payloads
APPSYNC_ENDPOINT=https://wpfcpehf2zfn7lqz4rriy3yfum.appsync-api.ap-south-1.amazonaws.com/graphql
APPSYNC_API_KEY=
S3_BUCKET_STUDENT=studaxis-student-stats-2026
S3_BUCKET_CONTENT=studaxis-content-2026

# App Settings
MAX_CONTEXT_TOKENS=4096
INFERENCE_TIMEOUT=30
SYNC_RETRY_ATTEMPTS=3
SYNC_RETRY_DELAY=5

# Feature Flags
ENABLE_CLOUD_SYNC=true
ENABLE_HINGLISH=true
ENABLE_PANIC_MODE=true
DEFAULT_THEME=dark
